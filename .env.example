# 读伴 · 示例环境变量(本地开发)
# 复制为 .env 并填入实际值

# 数据库:SQLite(零配置)/PostgreSQL
DATABASE_URL="file:./dev.db"
# DATABASE_URL="postgresql://user:pass@localhost:5432/duban"

# Auth.js:用 `openssl rand -base64 32` 生成
AUTH_SECRET="replace-me-with-32-random-chars"
AUTH_URL="http://localhost:3000"

# AI 接入(OpenAI 兼容):服务统一管理,用户走配额
# 留空则 AI 功能不可用,其余功能正常使用
AI_API_KEY=""
# 硅基流动 (SiliconFlow) ——
AI_BASE_URL="https://api.siliconflow.cn/v1"
AI_CHAT_MODEL="deepseek-ai/DeepSeek-V3"
AI_EMBED_MODEL="BAAI/bge-m3"
# 也可换其他 OpenAI 兼容服务:
# OpenAI:       https://api.openai.com/v1
# :     https://api./v1
# Ollama 本地:  http://localhost:11434/v1

# 配额(每日每用户)
QUOTA_MAX_TOKENS_PER_DAY="200000"
QUOTA_MAX_MESSAGES_PER_DAY="100"

# 上传文件大小(MB)
MAX_UPLOAD_MB="30"

# 是否开放注册
ALLOW_SIGNUP="true"
